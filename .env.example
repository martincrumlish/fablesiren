ANTHROPIC_KEY=sk-ant-your-key-here

# --- WhatsApp alert (Twilio) ---
# Your WhatsApp number in international format (the message recipient), plus your
# Twilio credentials. TWILIO_WHATSAPP_FROM defaults to Twilio's sandbox sender
# (whatsapp:+14155238886) if unset. See README "WhatsApp alerts".
WHATSAPP_PHONE=+441234567890
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional: use an approved WhatsApp template instead of freeform text. Needed
# if the alert may fire >24h after you last messaged the sandbox/sender.
# TWILIO_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_VARS={"1":"claude-fable-5"}

# --- De-dupe store for the headless cron (Vercel KV / Upstash Redis) ---
# Auto-added by Vercel when you connect a KV store to the project. Without these
# the cron cannot remember it already messaged you and will re-send every run.
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-token

# Optional: if set, /api/cron requires Vercel's cron auth header (Vercel sends
# it automatically). Leave unset to allow manual/unauthenticated calls.
CRON_SECRET=
